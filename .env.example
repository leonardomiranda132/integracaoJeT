# --------------------------------------------------
# Integracao - Configuracoes gerais
# --------------------------------------------------
APP_ENV=production
APP_TIMEZONE=America/Sao_Paulo
APP_LOG_LEVEL=info
INTEGRATION_DRY_RUN=true
PERSISTENCE_ADAPTER=postgres
JT_SEND_ENABLED=false
DAILY_SEND_LIMIT=

# Use DATABASE_URL ou POSTGRES_URL para persistencia duravel.
DATABASE_URL=postgres://usuario:senha@localhost:5432/integracao_jt
# POSTGRES_URL=postgres://usuario:senha@localhost:5432/integracao_jt
POSTGRES_SSL=false
POSTGRES_SSL_REJECT_UNAUTHORIZED=true
POSTGRES_POOL_MAX=10
DATABASE_MIGRATIONS_DIR=database/migrations

# --------------------------------------------------
# Virtual Age / TOTVS Moda
# --------------------------------------------------
VIRTUAL_AGE_ENVIRONMENT=producao
VIRTUAL_AGE_BASE_URL=https://www30.bhan.com.br:9443
VIRTUAL_AGE_AUTH_URL=https://www30.bhan.com.br:9443/api/totvsmoda/authorization/v2/token
VIRTUAL_AGE_SALES_ORDER_BASE_URL=https://www30.bhan.com.br:9443/api/totvsmoda/sales-order/v2
VIRTUAL_AGE_GRANT_TYPE=password
VIRTUAL_AGE_CLIENT_ID=seu_client_id
VIRTUAL_AGE_CLIENT_SECRET=seu_client_secret
VIRTUAL_AGE_USERNAME=seu_usuario
VIRTUAL_AGE_PASSWORD=sua_senha
VIRTUAL_AGE_BRANCH=313
VIRTUAL_AGE_REFRESH_TOKEN=
VIRTUAL_AGE_X_API_KEY=
VIRTUAL_AGE_BRANCH_CODES=313
VIRTUAL_AGE_SHIPPING_COMPANY_CODE=88442
VIRTUAL_AGE_ORDER_STATUS_LIST=Attended
VIRTUAL_AGE_ORDER_EXPAND=items,invoices,shippingAddress
VIRTUAL_AGE_ORDER_PAGE_SIZE=100
VIRTUAL_AGE_ORDER_MAX_PAGES=100

# --------------------------------------------------
# J&T Open Platform
# --------------------------------------------------
JT_ENVIRONMENT=producao
JT_BASE_URL=https://openapi.jtjms-br.com/webopenplatformapi/api
JT_API_ACCOUNT=sua_api_account
JT_PRIVATE_KEY=sua_private_key
JT_CUSTOMER_CODE=seu_customer_code
JT_CUSTOMER_PASSWORD=sua_customer_password
JT_EXPRESS_TYPE=standard
JT_ORDER_TYPE=2
JT_SERVICE_TYPE=01
JT_DELIVERY_TYPE=03
JT_PAY_TYPE=PP_PM
JT_GOODS_TYPE=bm000006
JT_PRINT_SIZE=0
JT_ORDER_STATUS_CALLBACK_URL=
JT_LOGISTICS_CALLBACK_URL=
JT_WEIGHT_CALLBACK_URL=
JT_INVOICE_TYPE=NFe
JT_RECEIVER_FALLBACK_PHONE=00000000000
JT_SENDER_NAME=NOME DO REMETENTE
JT_SENDER_TAX_NUMBER=00000000000000
JT_SENDER_MOBILE=00000000000
JT_SENDER_PHONE=00000000000
JT_SENDER_POST_CODE=00000000
JT_SENDER_STATE=SP
JT_SENDER_CITY=SAO PAULO
JT_SENDER_AREA=CENTRO
JT_SENDER_STREET=RUA EXEMPLO
JT_SENDER_STREET_NUMBER=0
JT_SENDER_ADDRESS=RUA EXEMPLO, 0
JT_SENDER_IE_NUMBER=

# --------------------------------------------------
# Monitoramento / reprocessamento manual
# --------------------------------------------------
ORDER_BRANCH_CODE=313
ORDER_CODE=
ORDER_OVERRIDE_PATCH=
ORDER_OVERRIDE_REASON=
ORDER_OVERRIDE_CREATED_BY=operator
REPROCESS_REASON=
REPROCESS_REQUESTED_BY=operator
REPROCESS_JT_SEND_ENABLED=false
REPROCESS_FORCE_SEND=false
REPROCESS_LIMIT=5
